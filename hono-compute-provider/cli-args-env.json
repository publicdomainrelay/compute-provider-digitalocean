{
  "options": [
    {
      "name": "port",
      "type": "integer",
      "env": "PORT",
      "default": 8080,
      "description": "HTTP port to listen on"
    },
    {
      "name": "provider",
      "type": "string",
      "env": "COMPUTE_PROVIDER",
      "default": "local",
      "description": "Compute provider mode: local or digitalocean"
    },
    {
      "name": "container-mode",
      "type": "boolean",
      "env": "CONTAINER_MODE",
      "default": true,
      "description": "Use container mode instead of QEMU (local only)"
    },
    {
      "name": "vm-image",
      "type": "string",
      "env": "VM_IMAGE",
      "default": "atcr.io/johnandersen777.bsky.social/ccripoc-qemu-runner",
      "description": "Docker image for QEMU VMs (local only)"
    },
    {
      "name": "container-image",
      "type": "string",
      "env": "CONTAINER_IMAGE",
      "default": "container-runner-ubuntu:latest",
      "description": "Docker image for container runner (local only)"
    },
    {
      "name": "cache-dir",
      "type": "string",
      "env": "CACHE_DIR",
      "description": "Cache directory for temp files (local only)"
    },
    {
      "name": "issuer-url",
      "type": "string",
      "env": "ISSUER_URL",
      "description": "OIDC issuer URL"
    },
    {
      "name": "operator-handle",
      "type": "string",
      "env": "OPERATOR_HANDLE",
      "description": "Operator handle (DID)"
    },
    {
      "name": "self-did",
      "type": "string",
      "env": "SELF_DID",
      "description": "This host's own DID"
    },
    {
      "name": "digitalocean-base-url",
      "type": "string",
      "env": "DIGITALOCEAN_BASE_URL",
      "default": "https://droplet-oidc.its1337.com",
      "description": "DigitalOcean-compatible API base URL"
    },
    {
      "name": "do-token",
      "type": "string",
      "env": "DO_TOKEN",
      "description": "DigitalOcean API token"
    }
  ]
}
