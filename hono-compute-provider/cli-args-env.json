{
  "name": "hono-compute-provider",
  "description": "Compute provider server — provisions droplets via local Docker or DigitalOcean API",
  "options": {
    "port": {
      "type": "number",
      "env": "PORT",
      "default": 8080,
      "description": "HTTP port to listen on"
    },
    "provider": {
      "type": "string",
      "env": "COMPUTE_PROVIDER",
      "default": "local",
      "description": "Compute provider mode: local or digitalocean"
    },
    "container-mode": {
      "type": "boolean",
      "env": "CONTAINER_MODE",
      "default": true,
      "description": "Use container mode instead of QEMU (local only)"
    },
    "vm-image": {
      "type": "string",
      "env": "VM_IMAGE",
      "default": "atcr.io/johnandersen777.bsky.social/ccripoc-qemu-runner",
      "description": "Docker image for QEMU VMs (local only)"
    },
    "container-image": {
      "type": "string",
      "env": "CONTAINER_IMAGE",
      "default": "container-runner-ubuntu:latest",
      "description": "Docker image for container runner (local only)"
    },
    "cache-dir": {
      "type": "string",
      "env": "CACHE_DIR",
      "description": "Cache directory for temp files (local only)"
    },
    "issuer-url": {
      "type": "string",
      "env": "ISSUER_URL",
      "default": "http://localhost:8080",
      "description": "OIDC issuer URL"
    },
    "operator-handle": {
      "type": "string",
      "env": "OPERATOR_HANDLE",
      "default": "did:plc:localhost",
      "description": "Operator handle (DID)"
    },
    "self-did": {
      "type": "string",
      "env": "SELF_DID",
      "default": "did:plc:localhost",
      "description": "This host's own DID"
    },
    "digitalocean-base-url": {
      "type": "string",
      "env": "DIGITALOCEAN_BASE_URL",
      "default": "https://droplet-oidc.its1337.com",
      "description": "DigitalOcean-compatible API base URL"
    },
    "do-token": {
      "type": "string",
      "env": "DO_TOKEN",
      "description": "DigitalOcean API token"
    },
    "hostname": {
      "type": "string",
      "env": "HOSTNAME",
      "default": "0.0.0.0",
      "description": "Hostname to bind to"
    },
    "log-level": {
      "type": "string",
      "env": "LOG_LEVEL",
      "default": "info",
      "description": "Minimum log level (debug, info, warn, error)"
    }
  }
}
